# Copy to .env for local Docker (never commit .env)

# MongoDB Atlas — required for API data
MONGODB_CONNECTION_STRING=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=your-app
MONGODB_DATABASE_NAME=solanist

# Bark webhook (maps to Webhooks__BarkSecret on BFF)
BARK_WEBHOOK_SECRET=demo-bark-secret

# AWS S3 — staff job photos (bucket: solanist)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=solanist
# Must match the bucket's AWS region (solanist bucket is eu-west-1)
S3_REGION=eu-west-1
# Optional CloudFront or custom domain for public URLs
S3_PUBLIC_BASE_URL=
S3_PUBLIC_READ=true

# Paystack — subscription billing (ZAR)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=http://localhost:8080/client/subscription
PAYSTACK_PLAN_QUARTERLY=

# Local Docker ports
BFF_EXTERNAL_PORT=8081
EXTERNAL_CLIENT_PORT=8080

# Google Sign-In (OAuth Web client ID from Google Cloud Console)
AUTH_GOOGLE_CLIENT_ID=
# Local smoke tests: mock:idToken login when Google SSO is enabled (never in production)
AUTH_ALLOW_MOCK_GOOGLE=true
# Allow self-service signup without an invite (testing/demos). Keep false in production.
AUTH_ALLOW_SELF_SIGNUP=false

# --- Render (set in Dashboard, not .env) ---
# Blueprint: render.yaml — both services use plan: starter (Frankfurt).
# solanist-bff service:
#   Mongo__ConnectionString  = your Atlas URI
#   Auth__SecretKey          = auto-generated by render.yaml (or set manually)
# solanist-app service:
#   BFF_UPSTREAM             = auto-linked from solanist-bff RENDER_EXTERNAL_URL
